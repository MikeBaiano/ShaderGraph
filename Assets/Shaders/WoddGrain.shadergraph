    "m_FunctionName": "LineNode",
    "m_FunctionSource": "",
    "m_FunctionBody": "A *= Scale;\nOut = smoothstep(0, 0.5 + B * 0.5,\nabs((sin(A * PI) + B * 2.0)) * 0.5);\n"
